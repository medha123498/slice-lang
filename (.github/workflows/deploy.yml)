name: Deploy Slice Lang

on:
 push:
  branches:
   - main

jobs:

 build:
  runs-on: ubuntu-latest

  steps:

  - uses: actions/checkout@v4

  - uses: mymindstorm/setup-emsdk@v14

  - name: Compile
    run: |
      emcc main.cpp \
      -o slice.js \
      -s EXPORTED_FUNCTIONS='["_calculate_pizza","_calculate_calories"]' \
      -s EXPORTED_RUNTIME_METHODS='["ccall"]'

  - name: Deploy
    uses: JamesIves/github-pages-deploy-action@v4
    with:
      folder: .
      branch: gh-pages
