body {
    font-family: 'Segoe UI', system-ui, sans-serif;
    background-color: #fff9f5;
    color: #2b2b2b;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    margin: 0;
}
.container {
    background: #ffffff;
    padding: 35px;
    border-radius: 20px;
    box-shadow: 0 15px 35px rgba(230, 92, 0, 0.06);
    max-width: 450px;
    width: 100%;
    text-align: center;
    border: 1px solid #ffe6d5;
}
h1 { color: #ff5500; margin-bottom: 5px; font-size: 2rem; }
.subtitle { color: #666; font-size: 13px; margin-bottom: 30px; letter-spacing: 0.5px; }
.configurator { text-align: left; margin-bottom: 25px; }
.section { margin-bottom: 22px; }
h3 { margin: 0 0 8px 0; font-size: 15px; color: #444; }
select { padding: 10px; width: 100%; border-radius: 8px; border: 1px solid #ffd0b3; background: #fffcfb; font-size: 14px; outline: none; }
label { font-size: 14px; display: inline-flex; align-items: center; margin-bottom: 8px; cursor: pointer; }
input[type="checkbox"] { width: 16px; height: 16px; margin-right: 10px; accent-color: #ff5500; }
.invoice { background: #fff2eb; padding: 20px; border-radius: 12px; border-left: 5px solid #ff5500; text-align: left; }
.invoice h2 { margin-top: 0; font-size: 16px; color: #ff5500; text-transform: uppercase; letter-spacing: 0.5px; }
#price { font-size: 26px; font-weight: 800; color: #ff5500; }
.btn { width: 100%; background: #ff5500; color: white; border: none; padding: 14px; border-radius: 8px; cursor: pointer; font-size: 16px; font-weight: 600; margin-top: 15px; transition: all 0.2s ease; }
.btn:hover { background: #e04b00; transform: translateY(-1px); }
